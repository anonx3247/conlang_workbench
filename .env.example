NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Keep out of client components and browser bundles.
SUPABASE_SECRET_KEY=

# Legacy Supabase keys are supported as fallbacks for older projects and local
# Supabase CLI output, but new hosted projects should use publishable/secret keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
